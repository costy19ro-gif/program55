teams_path = "teams.json"
teams_data = {}

if os.path.exists(teams_path):
    with open(teams_path, "r", encoding="utf-8") as f:
        teams_data = json.load(f)
else:
    st.warning("⚠️ Fișierul teams.json nu există. Se folosesc numele din scores24.json.")

def translate_team(liga, team_code):
    """Returnează numele real al echipei dacă există în teams.json."""
    return teams_data.get(liga, {}).get(team_code, team_code)
